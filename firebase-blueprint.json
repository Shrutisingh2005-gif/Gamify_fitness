{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and gamification stats",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "photoURL": { "type": "string" },
        "level": { "type": "integer" },
        "xp": { "type": "integer" },
        "streak": { "type": "integer" },
        "lastActive": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "displayName", "email"]
    },
    "Activity": {
      "title": "Activity",
      "description": "Daily health logs (exercise, nutrition, sleep)",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["exercise", "nutrition", "sleep", "water"] },
        "value": { "type": "number" },
        "unit": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "note": { "type": "string" }
      },
      "required": ["userId", "type", "value", "timestamp"]
    },
    "Challenge": {
      "title": "Challenge",
      "description": "Social challenges for users",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "type": { "type": "string" },
        "target": { "type": "number" },
        "rewardXP": { "type": "integer" },
        "participants": { "type": "array", "items": { "type": "string" } },
        "createdBy": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "completed"] }
      },
      "required": ["title", "type", "target", "rewardXP"]
    },
    "Notification": {
      "title": "Notification",
      "description": "User notifications and reminders",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string" },
        "read": { "type": "boolean" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "message", "read", "timestamp"]
    },
    "Message": {
      "title": "Message",
      "description": "Community chat messages",
      "type": "object",
      "properties": {
        "text": { "type": "string" },
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "senderPhoto": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["text", "senderId", "senderName", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/activities/{activityId}": {
      "schema": "Activity",
      "description": "User activity logs"
    },
    "/challenges/{challengeId}": {
      "schema": "Challenge",
      "description": "Global and friend challenges"
    },
    "/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "User specific notifications"
    },
    "/messages/{messageId}": {
      "schema": "Message",
      "description": "Global community messages"
    }
  }
}
